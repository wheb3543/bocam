{
    "workbench.editor.defaultBinaryEditor": "default",
    "files.exclude": {
        "/.next": true,
        "/.vite": true,
        "/dist": true,
        "/node_modules": true
    },
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit"
    }
}