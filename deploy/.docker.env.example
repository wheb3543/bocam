# Docker Environment Variables for BOCAM CRM Platform
# Copy this file to .docker.env and fill in your values

# Database (MySQL)
MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_DATABASE=bocam_crm
MYSQL_USER=bocam_user
MYSQL_PASSWORD=your-user-password
DATABASE_URL=mysql://bocam_user:your-user-password@mysql:3306/bocam_crm

# JWT Secret
JWT_SECRET=your-random-secret-key-here-change-this-in-production

# OAuth Server
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=your-oauth-app-id

# Heartbeat Server
CENTRAL_ACTIVATION_URL=https://api.ideahub.com/heartbeat

# Company Information
COMPANY_NAME=Your Hospital Name
COMPANY_ARABIC_NAME=اسم المستشفى
COMPANY_ENGLISH_NAME=Your Hospital
COMPANY_PHONE=+967 1 234 567
COMPANY_EMAIL=info@hospital.com

# WhatsApp Business API (optional)
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSWEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Meta Pixel (optional)
META_PIXEL_ID=your-meta-pixel-id
META_ACCESS_TOKEN=your-meta-access-token
