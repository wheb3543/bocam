# تحسينات الأداء للبيئة التطويرية
# Performance Optimization for Development Environment

# Vite Optimization
VITE_FAST_REFRESH=true
VITE_DISABLE_TS_CHECK=true

# Reduce logging
LOG_LEVEL=error

# Disable unnecessary features in development
VITE_DISABLE_ANALYTICS=true
VITE_DISABLE_TRACKING=true

# Database connection pooling
DB_POOL_SIZE=5
DB_CONNECTION_TIMEOUT=30000