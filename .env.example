# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/sgh_crm
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sgh_crm
DB_USER=root
DB_PASSWORD=password

# License Configuration (Internal - automatically managed)
# License validation is automatic based on hardware ID and cryptographic verification
# Do not manually set these values
# LICENSE_KEY: (auto-generated)
# HARDWARE_ID: (auto-detected)

# Company Information
COMPANY_NAME=Saudi German Hospital
COMPANY_ARABIC_NAME=المستشفى السعودي الألماني
COMPANY_ENGLISH_NAME=Saudi German Hospital
COMPANY_LOGO=/SGHHospitalColorBilingual.png

# Contact Information
COMPANY_PHONE=8000018
COMPANY_EMAIL=info@sgh.ye
COMPANY_ADDRESS=Sana'a, Yemen

# Social Media
FACEBOOK_URL=https://facebook.com/sgh
INSTAGRAM_URL=https://instagram.com/sgh
TWITTER_URL=
LINKEDIN_URL=

# Meta Pixel & Conversion API
META_PIXEL_ID=2008380493273171
META_ACCESS_TOKEN=your-meta-access-token
META_TEST_EVENT_CODE=TEST12345

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Email Service
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@sgh.ye
EMAIL_FROM_NAME=Saudi German Hospital

# SMS Service
SMS_SERVICE=twilio
SMS_API_KEY=your-twilio-api-key
SMS_API_SECRET=your-twilio-api-secret
SMS_PHONE_NUMBER=+1234567890

# OAuth Configuration
JWT_SECRET=your-jwt-secret-min-32-chars-for-security
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
VITE_APP_ID=your-app-id
OWNER_OPEN_ID=your-owner-openid
OWNER_NAME=Your Name

# Application Configuration
VITE_APP_TITLE=المستشفى السعودي الألماني - صنعاء
VITE_APP_LOGO=/SGHHospitalColorBilingual.png
PORT=3000
NODE_ENV=development

# Mocking Mode (Development Only)
MOCK_MODE=true
MOCK_WHATSAPP=true
MOCK_SMS=true
MOCK_EMAIL=true
MOCK_META_PIXEL=true
MOCK_LOGGING=true
MOCK_LOG_LEVEL=debug

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# Node.js Environment
NODE_OPTIONS=--max-old-space-size=4096
