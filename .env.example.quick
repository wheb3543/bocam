# ==============================================================================
# BOCAM CRM - Quick Start Environment Configuration (.env.example.quick)
# ==============================================================================
# ملف إعدادات سريع لبيئة التطوير المحلية باستخدام المحاكاة (Mock Mode)
# يتيح تشغيل المشروع بأقل متطلبات وإعدادات ممكنة في ثوانٍ معدودة.
# ==============================================================================

# 🌐 إعدادات التطبيق وبيئة العمل
NODE_ENV=development
PORT=3000

# 🗄️ قاعدة بيانات MySQL (مهيأة للربط المباشر مع Docker Compose)
DATABASE_URL=mysql://sgh_user:userpassword@localhost:3306/sgh_crm
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sgh_crm
DB_USER=sgh_user
DB_PASSWORD=userpassword

# 🔑 إعدادات حاوية MySQL لـ Docker Compose
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=sgh_crm
MYSQL_USER=sgh_user
MYSQL_PASSWORD=userpassword

# 🔐 المصادقة والحماية (أمن الجلسات)
JWT_SECRET=bocam_crm_quick_start_super_secret_key_32_chars_min
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
VITE_APP_ID=mock-app-id
VITE_OWNER_OPEN_ID=mock-owner-id
VITE_OWNER_NAME="المطور المحلي"

# 🎭 وضع المحاكاة (Mock Mode) - تفعيله يغنيك عن الربط الفعلي بالخدمات الخارجية
MOCK_MODE=true
MOCK_WHATSAPP=true
MOCK_SMS=true
MOCK_EMAIL=true
MOCK_META_PIXEL=true
MOCK_LOGGING=true
MOCK_LOG_LEVEL=debug

# ⚡ الذاكرة المؤقتة Redis (اختياري، يطابق إعدادات Docker Compose)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=defaultpassword

# 🏥 معلومات المستشفى الافتراضية
COMPANY_NAME="Saudi German Hospital"
COMPANY_ARABIC_NAME="المستشفى السعودي الألماني"
COMPANY_ENGLISH_NAME="Saudi German Hospital"
COMPANY_LOGO=/SGHHospitalColorBilingual.png
VITE_COMPANY_NAME="Saudi German Hospital"
VITE_COMPANY_ARABIC_NAME="المستشفى السعودي الألماني"
VITE_COMPANY_ENGLISH_NAME="Saudi German Hospital"
VITE_COMPANY_LOGO=/SGHHospitalColorBilingual.png
