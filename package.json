{
  "name": "sgh-crm-portal",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "node scripts/check-env.mjs",
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:fast": "cross-env NODE_ENV=development VITE_FAST_REFRESH=true tsx watch server/_core/index.ts",
    "build": "pnpm vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:analyze": "pnpm vite build --mode analyze",
    "prestart": "node scripts/check-env.mjs",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docker:build": "docker build -t sgh-crm-portal .",
    "docker:run": "docker run -p 3000:3000 sgh-crm-portal",
    "docker:compose:up": "docker-compose up",
    "docker:compose:down": "docker-compose down",
    "postinstall": "echo 'Post-install scripts skipped for performance'",
    "license:generate-keys": "tsx tools/generate-key-pair.ts",
    "license:generate": "tsx tools/generate-license-key.ts",
    "license:get-hardware-id": "tsx tools/get-hardware-id.ts",
    "analyze:perf": "node scripts/analyze-performance.mjs"
  },
